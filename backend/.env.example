# ─────────────────────────────────────────────
# SkillForge Backend - Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# Database
# DATABASE_URL=

# JWT
# JWT_SECRET=your_jwt_secret_here
# JWT_EXPIRES_IN=7d

# AI Service Keys
# OPENAI_API_KEY=your_openai_api_key_here
